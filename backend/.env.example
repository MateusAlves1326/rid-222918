PORT=3000
# Defina com a URL do seu frontend em produção (ex: https://seu-app.vercel.app)
# Em desenvolvimento, deixe como http://localhost:5173
FRONTEND_URL=http://localhost:5173
# O backend aceita automaticamente: localhost:*, *.vercel.app, *.netlify.app

# Supabase Configuration (Required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# Fallback caso nao tenha service key (menos recomendado no backend)
# SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key